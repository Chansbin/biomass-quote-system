{
  "build": {
    "env": "prod",
    "command": "npm run build",
    "outputDir": "dist"
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js",
      "methods": ["GET", "POST", "PUT", "DELETE"],
      "continue": true
    },
    {
      "handle": "error-codes"
    }
  ],
  "version": 2
}